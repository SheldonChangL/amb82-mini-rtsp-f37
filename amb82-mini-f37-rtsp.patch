@@ -0,0 +1,38 @@
+/******************************************************************************
+ * qr_wifi_provision.h
+ *
+ * QR-code Wi-Fi provisioning for the AMB82-mini RTSP firmware.
+ *
+ * Boot flow (called from video_example_main, before the RTSP pipeline):
+ *   1. qr_prov_connect_saved()  -- try Wi-Fi credentials stored in flash.
+ *   2. qr_prov_scan_and_connect() -- if no/﻿stale creds, scan a Wi-Fi QR code,
+ *      connect, persist creds, then sys_reset() to boot straight into RTSP.
+ *
+ * A status LED (QR_LED_PIN) reports the current state to the user.
+ ******************************************************************************/
+#ifndef _QR_WIFI_PROVISION_H_
+#define _QR_WIFI_PROVISION_H_
+
+/*
+ * Try to connect using Wi-Fi credentials previously stored in flash.
+ * Returns 0 on success (connected + got IP), negative if there are no valid
+ * saved credentials or the connection failed.
+ */
+int qr_prov_connect_saved(void);
+
+/*
+ * Bring up the camera, continuously scan for a Wi-Fi QR code
+ * (WIFI:S:<ssid>;T:<WPA|WEP|nopass>;P:<password>;H:<true|false>;;),
+ * connect, persist the credentials, then sys_reset().
+ * This function does not return on success (the board reboots into RTSP).
+ */
+void qr_prov_scan_and_connect(void);
+
+/*
+ * Register the "QRCLR" console command, which erases the saved Wi-Fi and
+ * reboots into QR scan mode (for re-provisioning / testing the scan flow).
+ * Call once at startup.
+ */
+void qr_prov_register_cmds(void);
+
+#endif /* _QR_WIFI_PROVISION_H_ */
