diff --git a/project/realtek_amebapro2_v0_example/src/mmfv2_video_example/wifi_prov_service.c b/project/realtek_amebapro2_v0_example/src/mmfv2_video_example/wifi_prov_service.c
new file mode 100644
index 0000000..5cb7b0b
--- /dev/null
+++ b/project/realtek_amebapro2_v0_example/src/mmfv2_video_example/wifi_prov_service.c
@@ -0,0 +1,367 @@
+/******************************************************************************
+ * wifi_prov_service.c
+ *
+ * Custom BLE GATT Wi-Fi provisioning service for AMB82-mini (RTL8735B).
+ * See wifi_prov_service.h for the protocol / UUIDs.
+ *
+ * Table + callbacks mirror Realtek's simple_ble_service.c (proven pattern),
+ * with 6 attributes worth of characteristics for SSID/PASS/CTRL/STATUS/IP.
+ ******************************************************************************/
+#include <platform_opts_bt.h>
+
+#if defined(CONFIG_BT_PERIPHERAL) && CONFIG_BT_PERIPHERAL
+
+#include <string.h>
+#include <stdio.h>
+#include <trace_app.h>
+#include <simple_ble_service.h>   /* pulls profile_server.h + gatt.h + GATT macros */
+#include <gap.h>
+#include <app_common_flags.h>
+#include "wifi_prov_service.h"
+
+#include <wifi_conf.h>
+#include <lwip_netconf.h>
+#include "FreeRTOS.h"
+#include "task.h"
+#include "semphr.h"
+#include "sys_api.h"             /* sys_reset */
+
+/* Persist Wi-Fi creds to flash (Realtek fast-connect). */
+extern int write_fast_connect_data_to_flash(unsigned int offer_ip, unsigned int server_ip);
+
+/*============================================================================
+ * 16-bit UUIDs
+ *==========================================================================*/
+#define WP_UUID_SERVICE   0xA100
+#define WP_UUID_SSID      0xA101
+#define WP_UUID_PASS      0xA102
+#define WP_UUID_CTRL      0xA103
+#define WP_UUID_STATUS    0xA104
+#define WP_UUID_IP        0xA105
+
+/* Attribute indices into wifi_prov_tbl[] (0-based). */
+#define WP_IDX_SSID          2
+#define WP_IDX_PASS          4
+#define WP_IDX_CTRL          6
+#define WP_IDX_STATUS        8
+#define WP_IDX_STATUS_CCCD   9
+#define WP_IDX_IP            11
+#define WP_IDX_IP_CCCD       12
+
+/* STATUS codes (match BLE-PROVISION-PROTOCOL.md / test GUI). */
+#define WP_ST_IDLE        0x00
+#define WP_ST_CONNECTING  0x01
+#define WP_ST_CONNECTED   0x02
+#define WP_ST_FAIL        0x03
+#define WP_ST_WRONG_PW    0x04
+
+/*============================================================================
+ * State
+ *==========================================================================*/
+static T_SERVER_ID wp_srv_id = 0xff;
+static uint8_t  wp_conn_id = 0;
+
+static uint8_t  wp_ssid[33];   static uint16_t wp_ssid_len = 0;
+static uint8_t  wp_pass[65];   static uint16_t wp_pass_len = 0;
+static uint8_t  wp_status_val[1] = { WP_ST_IDLE };
+static uint8_t  wp_ip_val[20]  = {0};   static uint16_t wp_ip_len = 0;
+
+static SemaphoreHandle_t wp_connect_sema = NULL;
+
+/*============================================================================
+ * GATT attribute table
+ *==========================================================================*/
+static const T_ATTRIB_APPL wifi_prov_tbl[] = {
+	/* [0] Primary Service */
+	{
+		(ATTRIB_FLAG_VALUE_INCL | ATTRIB_FLAG_LE),
+		{ LO_WORD(GATT_UUID_PRIMARY_SERVICE), HI_WORD(GATT_UUID_PRIMARY_SERVICE),
+		  LO_WORD(WP_UUID_SERVICE), HI_WORD(WP_UUID_SERVICE) },
+		UUID_16BIT_SIZE, NULL, GATT_PERM_READ
+	},
+	/* [1] SSID char decl (write) */
+	{
+		ATTRIB_FLAG_VALUE_INCL,
+		{ LO_WORD(GATT_UUID_CHARACTERISTIC), HI_WORD(GATT_UUID_CHARACTERISTIC),
+		  (GATT_CHAR_PROP_WRITE | GATT_CHAR_PROP_WRITE_NO_RSP) },
+		1, NULL, GATT_PERM_READ
+	},
+	/* [2] SSID value */
+	{
+		ATTRIB_FLAG_VALUE_APPL,
+		{ LO_WORD(WP_UUID_SSID), HI_WORD(WP_UUID_SSID) },
+		0, NULL, GATT_PERM_WRITE
+	},
+	/* [3] PASS char decl (write) */
+	{
+		ATTRIB_FLAG_VALUE_INCL,
+		{ LO_WORD(GATT_UUID_CHARACTERISTIC), HI_WORD(GATT_UUID_CHARACTERISTIC),
+		  (GATT_CHAR_PROP_WRITE | GATT_CHAR_PROP_WRITE_NO_RSP) },
+		1, NULL, GATT_PERM_READ
+	},
+	/* [4] PASS value */
+	{
+		ATTRIB_FLAG_VALUE_APPL,
+		{ LO_WORD(WP_UUID_PASS), HI_WORD(WP_UUID_PASS) },
+		0, NULL, GATT_PERM_WRITE
+	},
+	/* [5] CTRL char decl (write) */
+	{
+		ATTRIB_FLAG_VALUE_INCL,
+		{ LO_WORD(GATT_UUID_CHARACTERISTIC), HI_WORD(GATT_UUID_CHARACTERISTIC),
+		  (GATT_CHAR_PROP_WRITE | GATT_CHAR_PROP_WRITE_NO_RSP) },
+		1, NULL, GATT_PERM_READ
+	},
+	/* [6] CTRL value */
+	{
+		ATTRIB_FLAG_VALUE_APPL,
+		{ LO_WORD(WP_UUID_CTRL), HI_WORD(WP_UUID_CTRL) },
+		0, NULL, GATT_PERM_WRITE
+	},
+	/* [7] STATUS char decl (read + notify) */
+	{
+		ATTRIB_FLAG_VALUE_INCL,
+		{ LO_WORD(GATT_UUID_CHARACTERISTIC), HI_WORD(GATT_UUID_CHARACTERISTIC),
+		  (GATT_CHAR_PROP_READ | GATT_CHAR_PROP_NOTIFY) },
+		1, NULL, GATT_PERM_READ
+	},
+	/* [8] STATUS value */
+	{
+		ATTRIB_FLAG_VALUE_APPL,
+		{ LO_WORD(WP_UUID_STATUS), HI_WORD(WP_UUID_STATUS) },
+		0, NULL, GATT_PERM_READ
+	},
+	/* [9] STATUS CCCD */
+	{
+		(ATTRIB_FLAG_VALUE_INCL | ATTRIB_FLAG_CCCD_APPL),
+		{ LO_WORD(GATT_UUID_CHAR_CLIENT_CONFIG), HI_WORD(GATT_UUID_CHAR_CLIENT_CONFIG),
+		  LO_WORD(GATT_CLIENT_CHAR_CONFIG_DEFAULT), HI_WORD(GATT_CLIENT_CHAR_CONFIG_DEFAULT) },
+		2, NULL, (GATT_PERM_READ | GATT_PERM_WRITE)
+	},
+	/* [10] IP char decl (read + notify) */
+	{
+		ATTRIB_FLAG_VALUE_INCL,
+		{ LO_WORD(GATT_UUID_CHARACTERISTIC), HI_WORD(GATT_UUID_CHARACTERISTIC),
+		  (GATT_CHAR_PROP_READ | GATT_CHAR_PROP_NOTIFY) },
+		1, NULL, GATT_PERM_READ
+	},
+	/* [11] IP value */
+	{
+		ATTRIB_FLAG_VALUE_APPL,
+		{ LO_WORD(WP_UUID_IP), HI_WORD(WP_UUID_IP) },
+		0, NULL, GATT_PERM_READ
+	},
+	/* [12] IP CCCD */
+	{
+		(ATTRIB_FLAG_VALUE_INCL | ATTRIB_FLAG_CCCD_APPL),
+		{ LO_WORD(GATT_UUID_CHAR_CLIENT_CONFIG), HI_WORD(GATT_UUID_CHAR_CLIENT_CONFIG),
+		  LO_WORD(GATT_CLIENT_CHAR_CONFIG_DEFAULT), HI_WORD(GATT_CLIENT_CHAR_CONFIG_DEFAULT) },
+		2, NULL, (GATT_PERM_READ | GATT_PERM_WRITE)
+	},
+};
+
+/*============================================================================
+ * Notify helpers
+ *==========================================================================*/
+static void wp_notify_status(uint8_t st)
+{
+	wp_status_val[0] = st;
+	server_send_data(wp_conn_id, wp_srv_id, WP_IDX_STATUS, wp_status_val, 1, GATT_PDU_TYPE_ANY);
+	printf("[WP-BLE] STATUS -> 0x%02x\r\n", st);
+}
+static void wp_notify_ip(void)
+{
+	server_send_data(wp_conn_id, wp_srv_id, WP_IDX_IP, wp_ip_val, wp_ip_len, GATT_PDU_TYPE_ANY);
+	printf("[WP-BLE] IP -> %s\r\n", (char *)wp_ip_val);
+}
+
+/*============================================================================
+ * Provisioning worker task: connect -> notify -> persist -> reboot into RTSP
+ *==========================================================================*/
+static int wp_wait_for_ip(int timeout_10ms)
+{
+	int t = 0;
+	while (*(uint32_t *)LwIP_GetIP(0) == IP_ADDR_INVALID) {
+		vTaskDelay(10);
+		if (++t >= timeout_10ms) {
+			return -1;
+		}
+	}
+	return 0;
+}
+
+static void wp_connect_task(void *arg)
+{
+	(void)arg;
+#if defined(configENABLE_TRUSTZONE) && (configENABLE_TRUSTZONE == 1)
+	rtw_create_secure_context(2048);
+#endif
+	while (1) {
+		if (xSemaphoreTake(wp_connect_sema, portMAX_DELAY) != pdTRUE) {
+			continue;
+		}
+
+		rtw_network_info_t info = {0};
+		memcpy(info.ssid.val, wp_ssid, wp_ssid_len);
+		info.ssid.len = wp_ssid_len;
+		if (wp_pass_len > 0) {
+			info.security_type = RTW_SECURITY_WPA2_AES_PSK;
+			info.password = wp_pass;
+			info.password_len = wp_pass_len;
+		} else {
+			info.security_type = RTW_SECURITY_OPEN;
+		}
+
+		printf("[WP-BLE] connecting ssid='%s' (%s)\r\n", (char *)info.ssid.val,
+			   (wp_pass_len > 0) ? "WPA2" : "open");
+		wp_notify_status(WP_ST_CONNECTING);
+
+		int ret = wifi_connect(&info, 1);
+		if (ret == RTW_INVALID_KEY) {
+			printf("[WP-BLE] wrong password\r\n");
+			wp_notify_status(WP_ST_WRONG_PW);
+			continue;
+		}
+		if (ret != RTW_SUCCESS) {
+			printf("[WP-BLE] connect failed (%d)\r\n", ret);
+			wp_notify_status(WP_ST_FAIL);
+			continue;
+		}
+		LwIP_DHCP(0, 0);
+		if (wp_wait_for_ip(500) != 0) {
+			printf("[WP-BLE] no IP\r\n");
+			wp_notify_status(WP_ST_FAIL);
+			continue;
+		}
+
+		uint8_t *ip = LwIP_GetIP(0);
+		wp_ip_len = snprintf((char *)wp_ip_val, sizeof(wp_ip_val), "%d.%d.%d.%d",
+							 ip[0], ip[1], ip[2], ip[3]);
+		wp_notify_ip();
+		wp_notify_status(WP_ST_CONNECTED);
+
+		/* Persist so the next boot auto-connects + starts RTSP. */
+		write_fast_connect_data_to_flash(0, 0);
+		printf("[WP-BLE] connected + saved, rebooting into RTSP...\r\n");
+		vTaskDelay(1500);   /* let the notify flush to the phone */
+		sys_reset();        /* does not return */
+	}
+}
+
+/*============================================================================
+ * GATT callbacks
+ *==========================================================================*/
+static T_APP_RESULT wp_attr_read_cb(uint8_t conn_id, T_SERVER_ID service_id,
+									uint16_t attrib_index, uint16_t offset,
+									uint16_t *p_length, uint8_t **pp_value)
+{
+	(void)conn_id; (void)service_id; (void)offset;
+	switch (attrib_index) {
+	case WP_IDX_STATUS:
+		*pp_value = wp_status_val; *p_length = 1; return APP_RESULT_SUCCESS;
+	case WP_IDX_IP:
+		*pp_value = wp_ip_val; *p_length = wp_ip_len; return APP_RESULT_SUCCESS;
+	default:
+		return APP_RESULT_ATTR_NOT_FOUND;
+	}
+}
+
+static void wp_write_post_cb(uint8_t conn_id, T_SERVER_ID service_id, uint16_t attrib_index,
+							 uint16_t length, uint8_t *p_value)
+{
+	(void)conn_id; (void)service_id; (void)attrib_index; (void)length; (void)p_value;
+}
+
+static T_APP_RESULT wp_attr_write_cb(uint8_t conn_id, T_SERVER_ID service_id,
+									 uint16_t attrib_index, T_WRITE_TYPE write_type,
+									 uint16_t length, uint8_t *p_value,
+									 P_FUN_WRITE_IND_POST_PROC *p_write_ind_post_proc)
+{
+	(void)service_id; (void)write_type;
+	*p_write_ind_post_proc = wp_write_post_cb;
+	wp_conn_id = conn_id;
+
+	if (p_value == NULL && attrib_index != WP_IDX_CTRL) {
+		return APP_RESULT_INVALID_VALUE_SIZE;
+	}
+
+	switch (attrib_index) {
+	case WP_IDX_SSID:
+		if (length == 0 || length > 32) {
+			return APP_RESULT_INVALID_VALUE_SIZE;
+		}
+		memcpy(wp_ssid, p_value, length);
+		wp_ssid[length] = '\0';
+		wp_ssid_len = length;
+		printf("[WP-BLE] SSID set (%d bytes)\r\n", length);
+		return APP_RESULT_SUCCESS;
+
+	case WP_IDX_PASS:
+		if (length > 64) {
+			return APP_RESULT_INVALID_VALUE_SIZE;
+		}
+		if (length) {
+			memcpy(wp_pass, p_value, length);
+		}
+		wp_pass[length] = '\0';
+		wp_pass_len = length;
+		printf("[WP-BLE] PASS set (%d bytes)\r\n", length);
+		return APP_RESULT_SUCCESS;
+
+	case WP_IDX_CTRL:
+		if (length >= 1 && p_value && p_value[0] == 0x01) {
+			if (wp_ssid_len == 0) {
+				printf("[WP-BLE] CTRL connect but no SSID\r\n");
+				wp_notify_status(WP_ST_FAIL);
+			} else if (wp_connect_sema) {
+				printf("[WP-BLE] CTRL=0x01 -> trigger connect\r\n");
+				xSemaphoreGive(wp_connect_sema);
+			}
+		}
+		return APP_RESULT_SUCCESS;
+
+	default:
+		return APP_RESULT_ATTR_NOT_FOUND;
+	}
+}
+
+static void wp_cccd_update_cb(uint8_t conn_id, T_SERVER_ID service_id, uint16_t index,
+							  uint16_t cccbits)
+{
+	(void)conn_id; (void)service_id;
+	if (index == WP_IDX_STATUS_CCCD) {
+		printf("[WP-BLE] STATUS CCCD = 0x%x\r\n", cccbits);
+	} else if (index == WP_IDX_IP_CCCD) {
+		printf("[WP-BLE] IP CCCD = 0x%x\r\n", cccbits);
+	}
+}
+
+static const T_FUN_GATT_SERVICE_CBS wifi_prov_cbs = {
+	wp_attr_read_cb,
+	wp_attr_write_cb,
+	wp_cccd_update_cb
+};
+
+/*============================================================================
+ * Public: register service + start worker task
+ *==========================================================================*/
+T_SERVER_ID wifi_prov_add_service(void)
+{
+	if (false == server_add_service(&wp_srv_id, (uint8_t *)wifi_prov_tbl,
+									sizeof(wifi_prov_tbl), wifi_prov_cbs)) {
+		printf("[WP-BLE] wifi_prov_add_service fail\r\n");
+		wp_srv_id = 0xff;
+		return wp_srv_id;
+	}
+
+	if (wp_connect_sema == NULL) {
+		wp_connect_sema = xSemaphoreCreateBinary();
+		if (xTaskCreate(wp_connect_task, "wp_connect", 1024, NULL, tskIDLE_PRIORITY + 2, NULL) != pdPASS) {
+			printf("[WP-BLE] wp_connect task create fail\r\n");
+		}
+	}
+	printf("[WP-BLE] Wi-Fi provisioning service added (id %d)\r\n", wp_srv_id);
+	return wp_srv_id;
+}
+
+#endif /* CONFIG_BT_PERIPHERAL */
