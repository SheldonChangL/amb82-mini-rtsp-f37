+/******************************************************************************
+ * wifi_prov_service.h
+ *
+ * Custom BLE GATT service for Wi-Fi provisioning on AMB82-mini (RTL8735B).
+ * App writes SSID / PASS / CTRL=0x01; firmware connects, reports STATUS + IP
+ * via notify, persists creds and reboots into RTSP.
+ *
+ * 16-bit UUIDs (SIG-base expansion, e.g. service 0xA100 = 0000a100-0000-1000-
+ * 8000-00805f9b34fb):
+ *   Service 0xA100 · SSID(W) 0xA101 · PASS(W) 0xA102 · CTRL(W) 0xA103
+ *   STATUS(R/N) 0xA104 · IP(R/N) 0xA105
+ ******************************************************************************/
+#ifndef _WIFI_PROV_SERVICE_H_
+#define _WIFI_PROV_SERVICE_H_
+
+#include <platform_opts_bt.h>
+
+#if defined(CONFIG_BT_PERIPHERAL) && CONFIG_BT_PERIPHERAL
+#include <profile_server.h>
+
+/* Add the Wi-Fi provisioning service to the GATT database. Call from
+ * app_le_profile_init(). Returns the assigned service id (0xFF on failure). */
+T_SERVER_ID wifi_prov_add_service(void);
+
+#endif /* CONFIG_BT_PERIPHERAL */
+#endif /* _WIFI_PROV_SERVICE_H_ */
