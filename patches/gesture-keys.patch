@@ -0,0 +1,118 @@
+/******************************************************************************
+*
+* gesture_detect.c - two-finger (index+middle) horizontal swipe detector
+*
+* Pure logic, no I/O. Finger counting uses normalized-space landmarks
+* (middle finger up, so "extended" == fingertip.y < pip.y). Swipe tracking
+* uses the image-space palm-center x.
+*
+******************************************************************************/
+#include <stdbool.h>
+#include <math.h>
+
+/* module_vipnn.h needs bool / mm_module_t -> include prerequisites first. */
+#include "mmf2_module.h"
+#include "module_vipnn.h"
+
+#include "platform_opts.h"
+#include "gesture_detect.h"
+
+#ifndef GESTURE_SWIPE_RATIO
+#define GESTURE_SWIPE_RATIO      0.15f
+#endif
+#ifndef GESTURE_SWIPE_WINDOW_MS
+#define GESTURE_SWIPE_WINDOW_MS  500
+#endif
+#ifndef GESTURE_DEBOUNCE_MS
+#define GESTURE_DEBOUNCE_MS      500
+#endif
+
+/* MediaPipe 21-point hand landmark indices */
+#define LM_THUMB_TIP    4
+#define LM_THUMB_MCP    2
+#define LM_INDEX_TIP    8
+#define LM_INDEX_PIP    6
+#define LM_MIDDLE_TIP   12
+#define LM_MIDDLE_PIP   10
+#define LM_RING_TIP     16
+#define LM_RING_PIP     14
+#define LM_PINKY_TIP    20
+#define LM_PINKY_PIP    18
+
+typedef struct {
+	bool window_active;     /* a swipe window is currently being tracked */
+	float start_x;          /* image-space palm x at window start */
+	uint32_t start_ms;      /* window start time */
+	uint32_t lock_until_ms; /* debounce: ignore swipes until this time */
+} gesture_state_t;
+
+static gesture_state_t s_state = {0};
+
+/* Returns true if the pose is "index + middle extended, ring + pinky folded".
+ * In normalized space the middle finger points up, so a smaller y means the
+ * point is higher (more extended). */
+static bool is_two_finger_pose(const handland_res_t *res)
+{
+	const struct __post3d_s *p = res->landmark3d.pos;
+
+	bool index_up   = p[LM_INDEX_TIP].y  < p[LM_INDEX_PIP].y;
+	bool middle_up  = p[LM_MIDDLE_TIP].y < p[LM_MIDDLE_PIP].y;
+	bool ring_down  = p[LM_RING_TIP].y   >= p[LM_RING_PIP].y;
+	bool pinky_down = p[LM_PINKY_TIP].y  >= p[LM_PINKY_PIP].y;
+
+	/* Index+middle straight while ring+pinky folded cleanly rejects a fist
+	 * (nothing extended) and an open / four-finger hand (ring & pinky extended). */
+	return index_up && middle_up && ring_down && pinky_down;
+}
+
+void gesture_detect_reset(void)
+{
+	s_state.window_active = false;
+}
+
+gesture_dir_t gesture_detect_update(const struct handland_res_s *res_norm_space,
+									float palm_center_x_img, int img_width, uint32_t now_ms)
+{
+	const handland_res_t *res = (const handland_res_t *)res_norm_space;
+
+	if (!res || img_width <= 0) {
+		gesture_detect_reset();
+		return GESTURE_NONE;
+	}
+
+	/* Debounce: one swipe -> one tap. */
+	if (now_ms < s_state.lock_until_ms) {
+		return GESTURE_NONE;
+	}
+
+	if (!is_two_finger_pose(res)) {
+		gesture_detect_reset();
+		return GESTURE_NONE;
+	}
+
+	/* Pose held: (re)start or evaluate the swipe window. */
+	if (!s_state.window_active) {
+		s_state.window_active = true;
+		s_state.start_x = palm_center_x_img;
+		s_state.start_ms = now_ms;
+		return GESTURE_NONE;
+	}
+
+	/* Window expired without enough displacement -> slide window forward. */
+	if ((now_ms - s_state.start_ms) > GESTURE_SWIPE_WINDOW_MS) {
+		s_state.start_x = palm_center_x_img;
+		s_state.start_ms = now_ms;
+		return GESTURE_NONE;
+	}
+
+	float dx = palm_center_x_img - s_state.start_x;
+	if (fabsf(dx) / (float)img_width >= GESTURE_SWIPE_RATIO) {
+		s_state.window_active = false;
+		s_state.lock_until_ms = now_ms + GESTURE_DEBOUNCE_MS;
+		/* dx < 0 -> moved left ; dx > 0 -> moved right.
+		 * (Image x may be mirrored by the ISP; verify on-device and swap if needed.) */
+		return (dx < 0) ? GESTURE_LEFT : GESTURE_RIGHT;
+	}
+
+	return GESTURE_NONE;
+}
diff --git a/project/realtek_amebapro2_v0_example/src/mmfv2_video_example/gesture_detect.h b/project/realtek_amebapro2_v0_example/src/mmfv2_video_example/gesture_detect.h
