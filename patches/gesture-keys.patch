index 0000000..2985bd9
--- /dev/null
+++ b/project/realtek_amebapro2_v0_example/src/mmfv2_video_example/gesture_detect.h
@@ -0,0 +1,50 @@
+/******************************************************************************
+*
+* gesture_detect.h - pure two-finger-swipe detection state machine (no I/O)
+*
+* NOTE: This header intentionally does NOT include "module_vipnn.h".
+* module_vipnn.h depends on bool / mm_module_t and would fail to compile
+* without prior includes (stdbool.h, mmf2_module.h). We forward-declare the
+* result struct here and include module_vipnn.h only inside gesture_detect.c
+* (after its prerequisites). Callers pass a handland_res_t* which is the same
+* type as the forward-declared struct handland_res_s*.
+*
+******************************************************************************/
+#ifndef GESTURE_DETECT_H
+#define GESTURE_DETECT_H
+
+#include <stdint.h>
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+/* Defined in module_vipnn.h (handland_res_t == struct handland_res_s). */
+struct handland_res_s;
+
+typedef enum {
+	GESTURE_NONE = 0,
+	GESTURE_LEFT,
+	GESTURE_RIGHT
+} gesture_dir_t;
+
+/* Feed one hand-landmark result per frame.
+ *   res_norm_space    : landmarks in MODEL-NORMALIZED space (BEFORE fix_landmark),
+ *                       i.e. middle finger up. Used to count extended fingers.
+ *   palm_center_x_img : palm-center x in IMAGE space (AFTER fix_landmark). Used
+ *                       to track horizontal swipe displacement.
+ *   img_width         : image width for ratio-based threshold.
+ *   now_ms            : current time in milliseconds (FreeRTOS tick).
+ * Returns GESTURE_LEFT / GESTURE_RIGHT once per valid swipe (debounced),
+ * otherwise GESTURE_NONE. */
+gesture_dir_t gesture_detect_update(const struct handland_res_s *res_norm_space,
+									float palm_center_x_img, int img_width, uint32_t now_ms);
+
+/* Reset the swipe window/state (call when the hand leaves the frame). */
+void gesture_detect_reset(void);
+
+#ifdef __cplusplus
+}
+#endif
+
+#endif /* GESTURE_DETECT_H */
diff --git a/project/realtek_amebapro2_v0_example/src/mmfv2_video_example/gesture_event.c b/project/realtek_amebapro2_v0_example/src/mmfv2_video_example/gesture_event.c
