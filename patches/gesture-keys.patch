+++ b/project/realtek_amebapro2_v0_example/src/mmfv2_video_example/gesture_event.c
@@ -0,0 +1,88 @@
+/******************************************************************************
+*
+* gesture_event.c - UDP event sender for hand-gesture example
+*
+* Broadcasts the same wire protocol as the office presence event
+* (office_event.c): UDP broadcast 255.255.255.255:48555, JSON payload
+*   {"dev":"amb82-gesture","ts":<ms>,"gesture":"left|right"}
+* The desktop daemon (office_daemon.py) binds 48555 once and receives both
+* "amb82-office" and "amb82-gesture" events. Runs on its own non-blocking
+* sender socket alongside the RTSP stream; never touches the video pipeline.
+*
+******************************************************************************/
+#include "FreeRTOS.h"
+#include "task.h"
+#include <string.h>
+#include <platform_stdlib.h>
+
+#include "lwip/sockets.h"
+#include "lwip/inet.h"
+
+#include "platform_opts.h"
+#include "gesture_event.h"
+
+#define GESTURE_JSON_MAX  128
+
+static int gesture_sock = -1;
+static struct sockaddr_in gesture_dest;
+
+int gesture_event_init(void)
+{
+	int opt = 1;
+
+	gesture_sock = socket(AF_INET, SOCK_DGRAM, 0);
+	if (gesture_sock < 0) {
+		printf("[gesture_event] ERROR: socket() failed\n\r");
+		gesture_sock = -1;
+		return -1;
+	}
+
+	/* Allow broadcast to 255.255.255.255 (same as office_event.c). */
+	setsockopt(gesture_sock, SOL_SOCKET, SO_BROADCAST, &opt, sizeof(opt));
+
+	/* Non-blocking so a send can never stall the NN pipeline. */
+	fcntl(gesture_sock, F_SETFL, fcntl(gesture_sock, F_GETFL, 0) | O_NONBLOCK);
+
+	memset(&gesture_dest, 0, sizeof(gesture_dest));
+	gesture_dest.sin_family = AF_INET;
+	gesture_dest.sin_port = htons(GESTURE_EVENT_DEST_PORT);  /* 48555, shared bcast port */
+	gesture_dest.sin_addr.s_addr = htonl(INADDR_BROADCAST);  /* 255.255.255.255 */
+
+	printf("[gesture_event] UDP gesture events -> bcast :%d\n\r",
+		   GESTURE_EVENT_DEST_PORT);
+	return 0;
+}
+
+/* Build the JSON packet (matching office_event.c style) and broadcast it.
+ * direction must be the lowercase string "left" or "right" — the client
+ * dispatches on the exact "dev"/"gesture" strings. */
+void gesture_event_send_swipe(const char *direction)
+{
+	char json[GESTURE_JSON_MAX];
+	uint32_t t;
+	int ret;
+
+	if (gesture_sock < 0 || !direction) {
+		return;
+	}
+
+	t = (uint32_t)(xTaskGetTickCount() * portTICK_RATE_MS);
+	snprintf(json, sizeof(json),
+			 "{\"dev\":\"amb82-gesture\",\"ts\":%u,\"gesture\":\"%s\"}",
+			 (unsigned)t, direction);
+
+	ret = sendto(gesture_sock, json, strlen(json), 0,
+				 (struct sockaddr *)&gesture_dest, sizeof(gesture_dest));
+	if (ret < 0) {
+		/* Log only; never block the逐幀 DISPPOST callback. */
+		printf("[gesture_event] WARN: sendto failed\n\r");
+	}
+}
+
+void gesture_event_deinit(void)
+{
+	if (gesture_sock >= 0) {
+		close(gesture_sock);
+		gesture_sock = -1;
+	}
+}
