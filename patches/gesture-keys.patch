@@ -0,0 +1,32 @@
+/******************************************************************************
+*
+* gesture_event.h - UDP event sender for hand-gesture example
+*
+* Broadcasts JSON {"dev":"amb82-gesture","ts":<ms>,"gesture":"left|right"} over
+* a non-blocking UDP socket to 255.255.255.255:48555 — the same broadcast port
+* as office_event.c. The PC-side desktop app turns these into arrow keys.
+*
+******************************************************************************/
+#ifndef GESTURE_EVENT_H
+#define GESTURE_EVENT_H
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+/* Create the UDP socket and prepare the destination address.
+ * Returns 0 on success, non-zero on failure (logged). */
+int gesture_event_init(void);
+
+/* Broadcast a swipe event as JSON. direction is "left" or "right" (lowercase).
+ * Non-blocking; failures are logged and ignored so the NN pipeline never stalls. */
+void gesture_event_send_swipe(const char *direction);
+
+/* Close the UDP socket. */
+void gesture_event_deinit(void);
+
+#ifdef __cplusplus
+}
+#endif
+
+#endif /* GESTURE_EVENT_H */
